@page "/"
@page "/weather"
@rendermode InteractiveServer

@using WeatherApp.Domain.ValueObjects
@inject WeatherApp.Core.Services.GetCurrentWeatherService getCurrentWeatherService

<div class="weather-page">
    <div class="page-hero">
        <h1 class="page-title">
            <span class="title-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" focusable="false">
                    <path d="M6.8 18.6h10.7a3.5 3.5 0 0 0 .2-7 5.2 5.2 0 0 0-10.3-1.3A3.8 3.8 0 0 0 6.8 18.6Z" />
                    <path d="M8 20.5h7.8" />
                    <path d="M9.6 22.2h4.6" />
                </svg>
            </span>
            Weather
        </h1>
    </div>

    <EditForm Model="formModel" OnSubmit="LoadCurrentWeatherAsync">
        <div class="search-row glass">
            <div class="field">
                <label for="locationInput">Location</label>
                <input id="locationInput"
                       class="input"
                       @bind="formModel.LocationQueryText"
                       @bind:event="oninput"
                       placeholder="e.g., Bucharest"
                       disabled="@isLoading" />
            </div>

            <button type="submit" class="btn" disabled="@isLoading">
                @(isLoading ? "Searching..." : "Search")
            </button>
        </div>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert">@errorMessage</div>
    }

    @if (isLoading && currentWeather is null)
    {
        <div class="card glass skeleton-card">
            <div class="card-header">
                <div class="skeleton skeleton-text" style="width: 180px;"></div>
                <div class="skeleton skeleton-text" style="width: 90px;"></div>
            </div>
            <div class="card-body">
                <div class="skeleton skeleton-text" style="height: 48px; width: 160px;"></div>
                <div class="skeleton skeleton-text" style="width: 220px; margin-top: 12px;"></div>
                <div class="skeleton skeleton-text" style="width: 260px; margin-top: 14px;"></div>
            </div>
        </div>
    }

    @if (currentWeather is not null)
    {
        <div class="card glass fade-in">
            <div class="card-header">
                <div class="location">@currentWeather.LocationName</div>
                <div class="country">@currentWeather.CountryName</div>
            </div>

            <div class="card-body">
                <div class="temp">@currentWeather.TemperatureCelsius.ToString("0.0") °C</div>

                <div class="condition">
                    @if (!string.IsNullOrWhiteSpace(currentWeather.ConditionIconUrl))
                    {
                        <img class="icon" src="@currentWeather.ConditionIconUrl" alt="Weather icon" />
                    }
                    <span>@currentWeather.ConditionText</span>
                </div>

                <div class="meta">
                    <span>Humidity: <b>@currentWeather.HumidityPercentage%</b></span>
                    <span>Wind: <b>@currentWeather.WindKph.ToString("0.0") kph</b></span>
                </div>
            </div>
        </div>
    }

    @if (currentWeather is null && !isLoading && string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="empty-state glass">
            Search for a location to see the current conditions.
        </div>
    }
</div>

@code {
    private string locationQueryText = "Bucharest";
    private bool isLoading;
    private string? errorMessage;
    private CurrentWeather? currentWeather;

    private WeatherSearchFormModel formModel = new();

    private sealed class WeatherSearchFormModel
    {
        public string LocationQueryText { get; set; } = "Bucharest";
    }

    private async Task LoadCurrentWeatherAsync()
    {
        var trimmedQueryText = (formModel.LocationQueryText ?? string.Empty).Trim();

        if (trimmedQueryText.Length < 2)
        {
            errorMessage = "Please enter a valid location (at least 2 characters).";
            currentWeather = null;
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            currentWeather = await getCurrentWeatherService.ExecuteAsync(new LocationQuery(trimmedQueryText));
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            currentWeather = null;
        }
        finally
        {
            isLoading = false;
        }
    }
}